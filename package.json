{
  "name": "keep-watch",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:all": "npm run db:setup && next dev",
    "lint": "next lint",
    "start:postgres": "node scripts/start-postgres.js",
    "docker:all": "node scripts/docker-start-all.js",
    "docker:dev": "docker-compose up -d && next dev",
    "docker:dev:rebuild": "docker-compose up --build --force-recreate",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:clean": "docker-compose down -v",
    "dev:local": "node --experimental-json-modules scripts/dev-start.js",
    "dev:docker": "docker-compose -f docker-compose.dev.yml down && docker-compose -f docker-compose.dev.yml up --build",
    "dev:docker:rebuild": "docker-compose -f docker-compose.dev.yml down -v && docker-compose -f docker-compose.dev.yml up --build",
    "prisma:generate": "npx prisma generate",
    "prisma:studio": "npx prisma studio",
    "prisma:migrate": "npx prisma migrate dev",
    "db:setup": "node scripts/setup-db.js",
    "db:start": "docker-compose up -d postgres",
    "db:stop": "docker-compose down postgres",
    "db:reset": "prisma migrate reset --force",
    "demo": "npx ts-node scripts/demo.ts",
    "tailwind:build": "tailwindcss -i ./src/app/globals.css -o ./src/app/globals.css",
    "tailwind:watch": "tailwindcss -i ./src/app/globals.css -o ./src/app/globals.css --watch"
  },
  "dependencies": {
    "@chakra-ui/icons": "^2.0.19",
    "@chakra-ui/react": "^2.6.1",
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@prisma/client": "^4.14.1",
    "axios": "^1.4.0",
    "date-fns": "^2.30.0",
    "dotenv": "^16.0.3",
    "framer-motion": "^10.12.16",
    "googleapis": "^146.0.0",
    "next": "^13.4.3",
    "prisma": "^4.14.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-icons": "^4.8.0",
    "youtube-api-v3-search": "^1.2.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/pg": "^8.10.9",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.16",
    "eslint": "8.41.0",
    "eslint-config-next": "13.4.3",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
